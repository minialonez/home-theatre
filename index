<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Home Theater 5.1.2 — ห้องนั่งเล่นชั้น 3 (B&W 700 S3 Mocha)</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
  :root{
    --bg:#141010; --panel:#1E1713; --panel2:#241C16; --line:#382C21;
    --cream:#F0E7D9; --muted:#A2917C; --mocha:#B08760; --amber:#E2A45C;
    --cyan:#7FB6BA; --red:#CE6E4C; --green:#8FAF7E;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:var(--bg);color:var(--cream);font-family:'Sukhumvit Set','Noto Sans Thai',-apple-system,'Segoe UI',Tahoma,sans-serif;min-height:100vh}
  header{padding:22px 26px 14px;border-bottom:1px solid var(--line)}
  .eyebrow{font-size:11px;letter-spacing:.25em;color:var(--mocha);text-transform:uppercase;margin-bottom:6px}
  h1{font-size:clamp(19px,2.6vw,27px);font-weight:700;line-height:1.25}
  h1 span{color:var(--mocha)}
  .sub{color:var(--muted);font-size:13px;margin-top:5px}
  nav{display:flex;gap:8px;padding:12px 26px;border-bottom:1px solid var(--line);flex-wrap:wrap;position:sticky;top:0;background:var(--bg);z-index:20}
  .tab{background:var(--panel);border:1px solid var(--line);color:var(--muted);padding:9px 16px;border-radius:8px;cursor:pointer;font-size:14px;font-family:inherit}
  .tab.active{background:var(--mocha);color:#191008;border-color:var(--mocha);font-weight:700}
  main{padding:18px 26px 60px;max-width:1280px;margin:0 auto}
  .page{display:none}.page.active{display:block}

  /* ---------- 3D ---------- */
  .viewer-wrap{display:grid;grid-template-columns:1fr 300px;gap:14px}
  @media(max-width:900px){.viewer-wrap{grid-template-columns:1fr}}
  #canvas-holder{position:relative;background:radial-gradient(ellipse at 50% 30%,#241B14 0%,#100C0A 75%);border:1px solid var(--line);border-radius:12px;overflow:hidden;height:600px}
  #canvas-holder canvas{display:block;touch-action:none}
  .cam-hint{position:absolute;left:12px;bottom:10px;font-size:11.5px;color:var(--muted);background:rgba(20,16,16,.72);padding:5px 10px;border-radius:6px;pointer-events:none}
  .side{display:flex;flex-direction:column;gap:12px}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:14px 16px}
  .card h3{font-size:13px;letter-spacing:.14em;color:var(--mocha);text-transform:uppercase;margin-bottom:10px}
  .presets{display:grid;grid-template-columns:1fr 1fr;gap:7px}
  .preset{background:var(--panel2);border:1px solid var(--line);color:var(--cream);border-radius:8px;padding:9px 8px;font-size:13px;cursor:pointer;font-family:inherit;text-align:center}
  .preset:hover{border-color:var(--mocha)}
  .preset.on{background:var(--mocha);color:#191008;font-weight:700;border-color:var(--mocha)}
  #angle-note{font-size:13px;line-height:1.65;color:var(--cream)}
  #angle-note b{color:var(--amber)}
  .toggles label{display:flex;align-items:center;gap:9px;font-size:13.5px;padding:5px 0;cursor:pointer;color:var(--cream)}
  .toggles input{accent-color:var(--mocha);width:15px;height:15px}
  .legend{font-size:12.5px;line-height:1.9;color:var(--muted)}
  .dot{display:inline-block;width:9px;height:9px;border-radius:50%;margin-right:7px;vertical-align:1px}

  /* ---------- 2D / SVG ---------- */
  .plan-grid{display:grid;grid-template-columns:1fr;gap:16px}
  .svg-card{background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:16px}
  .svg-card h2{font-size:16px;margin-bottom:4px}
  .svg-card p.cap{color:var(--muted);font-size:13px;margin-bottom:12px;line-height:1.6}
  svg{width:100%;height:auto;display:block}
  .rules{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:12px;margin-top:16px}
  .rule{background:var(--panel2);border:1px solid var(--line);border-radius:10px;padding:13px 15px;font-size:13px;line-height:1.7}
  .rule b{color:var(--amber);display:block;margin-bottom:3px;font-size:13.5px}
  .rule .n{color:var(--mocha);font-weight:700}

  table{width:100%;border-collapse:collapse;font-size:13px;margin-top:10px}
  th{color:var(--mocha);text-align:left;font-weight:700;padding:8px 10px;border-bottom:1px solid var(--line);font-size:12px;letter-spacing:.06em}
  td{padding:8px 10px;border-bottom:1px solid #2A211A;color:var(--cream);line-height:1.5}
  td.mut{color:var(--muted)}
  .pill{display:inline-block;padding:2px 9px;border-radius:99px;font-size:11px;font-weight:700}
  .p-amber{background:rgba(226,164,92,.16);color:var(--amber)}
  .p-cyan{background:rgba(127,182,186,.16);color:var(--cyan)}
  .p-red{background:rgba(206,110,76,.16);color:var(--red)}
  .p-green{background:rgba(143,175,126,.16);color:var(--green)}
</style>
</head>
<body>

<header>
  <div class="eyebrow">Home Theater Design · 5.1.2</div>
  <h1>ห้องนั่งเล่น–โฮมเธียเตอร์ ชั้น 3 <span>· B&W 700 S3 Mocha + REL + Integra</span></h1>
  <div class="sub">ห้องกว้าง ~7.5 × ลึก 5.8 × สูง 2.8 ม. (กรอบแดงในแบบ) · จอผนังทิศใต้ · ระเบียงกระจกทิศตะวันออก · บาร์ผนังตะวันตก</div>
</header>

<nav>
  <button class="tab active" data-page="p3d">🎥 มุมมอง 3D (หมุนดูได้)</button>
  <button class="tab" data-page="p2d">📐 แปลน 2D + องศาเสียง</button>
  <button class="tab" data-page="pcable">🔌 เก็บสาย & ตู้แร็ค</button>
</nav>

<main>

<!-- ============ 3D PAGE ============ -->
<section class="page active" id="p3d">
  <div class="viewer-wrap">
    <div id="canvas-holder">
      <div class="cam-hint">ลากเมาส์ = หมุน · ลูกกลิ้ง/บีบนิ้ว = ซูม · ปุ่มขวา = เปลี่ยนมุมกล้อง</div>
    </div>
    <div class="side">
      <div class="card">
        <h3>ภาพนิ่ง — เลือกมุมกล้อง</h3>
        <div class="presets" id="presets"></div>
      </div>
      <div class="card">
        <h3>เหตุผลเชิงอะคูสติกของมุมนี้</h3>
        <div id="angle-note">เลือกมุมกล้องด้านบนเพื่อดูคำอธิบาย</div>
      </div>
      <div class="card toggles">
        <h3>แสดง/ซ่อน</h3>
        <label><input type="checkbox" id="tg-lines" checked> เส้นทางเสียง → จุดนั่งฟัง</label>
        <label><input type="checkbox" id="tg-labels" checked> ป้ายชื่ออุปกรณ์</label>
        <label><input type="checkbox" id="tg-tri" checked> สามเหลี่ยมการฟัง L–R–ผู้ฟัง</label>
      </div>
      <div class="card legend">
        <h3>อุปกรณ์ตามใบมัดจำ</h3>
        <span class="dot" style="background:var(--amber)"></span>B&W 703 S3 คู่หน้า L/R (Mocha)<br>
        <span class="dot" style="background:var(--amber)"></span>B&W HTM-72 S3 เซ็นเตอร์<br>
        <span class="dot" style="background:var(--green)"></span>B&W 706 S3 เซอร์ราวด์ (ขาตั้ง)<br>
        <span class="dot" style="background:var(--cyan)"></span>B&W CCM-382 ฝังฝ้า ×2 (Atmos)<br>
        <span class="dot" style="background:var(--red)"></span>REL HT-1205 MKII ซับวูฟเฟอร์<br>
        <span class="dot" style="background:var(--mocha)"></span>Integra DRX-5.4 ในตู้คอนโซลใต้จอ
      </div>
    </div>
  </div>
</section>

<!-- ============ 2D PAGE ============ -->
<section class="page" id="p2d">
  <div class="plan-grid">
    <div class="svg-card">
      <h2>แปลนจัดวาง — องศาและระยะตามมาตรฐาน Dolby / THX</h2>
      <p class="cap">แกนการฟังเยื้องมาอยู่กึ่งกลางช่วงผนังที่เหลือจากห้องน้ำ (ไม่ใช่กึ่งกลางห้อง) เพื่อให้ L–C–R สมมาตรกับจอ · โซฟาหลักลอยจากผนังหลัง ~1.5 ม. ไม่นั่งชิดผนัง</p>
      <svg viewBox="0 0 860 660" id="svgplan"></svg>
      <div class="rules">
        <div class="rule"><b>คู่หน้า 703 S3</b>ห่างกัน <span class="n">2.6 ม.</span> · ห่างผนังหลังลำโพง <span class="n">≥ 0.45 ม.</span> (มีท่อเบสด้านหลัง) · โทอิน <span class="n">15–20°</span> เล็งเข้าหาหัวผู้ฟัง · มุมรวม L–R จากจุดนั่ง ≈ <span class="n">45°</span> (THX แนะนำ 40–60°)</div>
        <div class="rule"><b>เซ็นเตอร์ HTM-72</b>กึ่งกลางใต้จอบนคอนโซล สูง ~0.55 ม. <span class="n">เงยขึ้นเล็กน้อย</span> ให้ทวีตเตอร์เล็งระดับหูขณะนั่ง (~1.05 ม.)</div>
        <div class="rule"><b>เซอร์ราวด์ 706 S3</b>ทำมุม <span class="n">±110°</span> จากแกนหน้า ข้างหลังไหล่ผู้ฟังเล็กน้อย · บนขาตั้งสูงให้ทวีตเตอร์อยู่ <span class="n">~1.2 ม.</span> (สูงกว่าหูเล็กน้อย)</div>
        <div class="rule"><b>เพดาน CCM-382 (Top Middle)</b>แนวเดียวกับหัวผู้ฟัง เยื้องหน้าเล็กน้อย ห่างแกนซ้าย–ขวาข้างละ <span class="n">1.05 ม.</span> — ตำแหน่ง 5.1.2 ตาม Dolby</div>
        <div class="rule"><b>ซับ REL HT-1205</b>เข้ามุมหน้า-ขวา (มุมผนังจอ×ผนังห้องน้ำ) ตามคำแนะนำ REL เพื่อ corner-loading · จูนด้วยการขยับออกจากมุมทีละ 10–20 ซม. ถ้าเบสบวมเกิน</div>
        <div class="rule"><b>สภาพห้อง</b>พรมหนาเต็มโซนนั่งฟัง · <span class="n">ม่านทึบหนา</span> ที่กระจกระเบียงฝั่งขวา (ลดสะท้อนข้างขวาที่ไม่สมมาตร + กันแสง) · ตู้บาร์ฝั่งซ้ายช่วยแตกเสียงสะท้อนไปในตัว</div>
      </div>
    </div>
  </div>
</section>

<!-- ============ CABLE PAGE ============ -->
<section class="page" id="pcable">
  <div class="plan-grid">
    <div class="svg-card">
      <h2>เส้นทางเดินสายทั้งห้อง (ฝังท่อรอก่อนปิดฝ้า/ฉาบ)</h2>
      <p class="cap">บ้านยังอยู่ในขั้นแบบก่อสร้าง — <b style="color:var(--amber)">ฝังท่อ PVC ร้อยสายรอไว้ตอนนี้คุ้มที่สุด</b> ทุกเส้นวิ่งจาก "จุดรวมสาย" หลังตู้คอนโซลใต้จอ ขึ้นผนัง → กระจายในฝ้า → หย่อนลงตามจุด ไม่มีสายลอยให้เห็นแม้แต่เส้นเดียว</p>
      <svg viewBox="0 0 860 640" id="svgcable"></svg>
    </div>

    <div class="svg-card">
      <h2>ตู้คอนโซล AV ใต้จอ — ผังภายใน (กว้าง 2.0 ม.)</h2>
      <p class="cap">Integra DRX-5.4 เป็นตัวปล่อยความร้อนหลัก ต้องมีช่องหายใจ · ทุกสายเข้า–ออกทางช่องแปรง (brush plate) ด้านหลัง มองจากหน้าตู้ไม่เห็นสายเลย</p>
      <svg viewBox="0 0 860 400" id="svgrack"></svg>
    </div>

    <div class="svg-card">
      <h2>รายการวัสดุเดินสาย (ของที่ร้านมีขายเกือบทั้งหมด)</h2>
      <table>
        <thead><tr><th>รายการ</th><th>สเปก</th><th>ใช้กับ</th><th>ประมาณ</th></tr></thead>
        <tbody>
          <tr><td>ท่อ PVC ร้อยสาย + ข้อต่อ</td><td>Ø20 มม. (สายลำโพง) / Ø25 มม. (HDMI)</td><td class="mut">เดินฝ้า + ฝังผนังทุกจุด</td><td>~45 ม.</td></tr>
          <tr><td>สายลำโพง OFC</td><td>2×2.5 มม.² (≈13AWG)</td><td class="mut">L / R / C / เซอร์ราวด์ / เพดาน — เผื่อปลาย 1.5 ม./จุด</td><td>~55 ม.</td></tr>
          <tr><td>บ็อกซ์ฝัง 4×4 + หน้ากาก Binding Post</td><td>speaker wall plate ขั้ว banana</td><td class="mut">จุดเซอร์ราวด์ L/R ที่ผนัง 2 จุด</td><td>2 ชุด</td></tr>
          <tr><td>หน้ากากช่องแปรง (brush plate)</td><td>ฝังผนังหลังจอ + หลังตู้คอนโซล</td><td class="mut">ทางเข้า–ออกสาย HDMI/ไฟ แบบไร้สายโผล่</td><td>2 จุด</td></tr>
          <tr><td>HDMI 2.1 (48Gbps)</td><td>จอ→AVR ~3 ม. (เกิน 5 ม. ใช้ Fiber HDMI)</td><td class="mut">ภาพ 4K/120 + eARC</td><td>1 เส้น</td></tr>
          <tr><td>สาย High-Level ของ REL (Speakon)</td><td>มากับเครื่อง 10 ม. — ร้อยในท่อได้</td><td class="mut">AVR → ซับ REL (เสียงต่อเนื่องกว่า LFE อย่างเดียว)</td><td>1 เส้น</td></tr>
          <tr><td><b>วงจรไฟแยกสำหรับชุดเครื่องเสียง</b></td><td>เบรกเกอร์ 20A + สาย 2.5 มม.² + กราวด์แท้</td><td class="mut">เต้ารับคู่หลังคอนโซล (เสียบ NRG-Y3 เข้า Integra) + หลังจอ 1 จุด</td><td>1 วงจร</td></tr>
          <tr><td>รางครอบสายแบบบัวพื้น (สำรอง)</td><td>50×25 มม. สีลายไม้</td><td class="mut">เฉพาะกรณีปิดฝ้าไปแล้ว ฝังท่อไม่ได้</td><td>ตามหน้างาน</td></tr>
        </tbody>
      </table>
      <div class="rules" style="margin-top:14px">
        <div class="rule"><b>กันสัญญาณกวน</b>ท่อสายลำโพง/HDMI ให้เดิน <span class="n">ห่างท่อสายไฟ AC ≥ 30 ซม.</span> ถ้าจำเป็นต้องตัดกัน ให้ตัดตั้งฉาก 90° ไม่เดินขนานกันยาว ๆ</div>
        <div class="rule"><b>เผื่ออนาคต 7.1.4</b>Integra DRX-5.4 รองรับ 11.2 — ฝังท่อเปล่า + สายดึง (pull string) ไปมุมหลังห้อง 2 จุด และเพดานหลังอีก 2 จุด <span class="n">ตอนนี้เลย</span> ค่าท่อไม่กี่ร้อยบาท แต่เจาะทีหลังคือรื้อฝ้า</div>
        <div class="rule"><b>กันเสียงฮัม (ground loop)</b>ปลั๊กของ<span class="n">ทุกเครื่องที่มีสายสัญญาณถึงกัน</span> (จอ, Integra, REL, เครื่องเล่น) ต้องมาจากเบรกเกอร์ลูกเดียวกัน = ลูก AV 20A นี้เท่านั้น · ปลั๊กอื่นของห้อง (บาร์/ผนัง) ใช้ลูกปกติของห้อง ห้ามพ่วงลูก AV · ห้ามตัดขากราวด์ปลั๊กเด็ดขาด</div>
        <div class="rule"><b>ระบายความร้อน Integra</b>ช่องวางสูงอย่างน้อย <span class="n">เว้นบน 10 ซม.</span> หลังตู้เปิดโล่งหรือเจาะรู + พัดลม 12 ซม. แบบเงียบ (ต่อ trigger 12V จาก AVR ให้หมุนเฉพาะตอนเปิดเครื่อง)</div>
      </div>
    </div>
  </div>
</section>

</main>

<script>
/* ================= TABS ================= */
document.querySelectorAll('.tab').forEach(b=>{
  b.onclick=()=>{
    document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
    document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
    b.classList.add('active');
    document.getElementById(b.dataset.page).classList.add('active');
    if(b.dataset.page==='p3d') onResize();
  };
});

/* ================= 3D SCENE =================
   หน่วยเป็นเมตร · x = ตะวันตก(-)→ตะวันออก(+) · z = เหนือ(-)→ใต้(+ ผนังจอ) · y = สูง
   ห้อง: x -3.75..3.75 (7.5ม.) · z -2.9..2.9 (5.8ม.) · สูง 2.8
   แกนฟัง x0 = -1.0 (กึ่งกลางผนังจอช่วงที่พ้นห้องน้ำ)               */
const X0=-1.0, EAR=1.05, MLPZ=-0.7;
const COL={wood:0x4a3728, wall:0x8f8577, wallD:0x6e655a, mocha:0x6b4a33, cab:0x3a2c20,
  sofa:0x5c4a38, rug:0x2e2620, tv:0x0d0d0f, spk:0x4e3a28};
const holder=document.getElementById('canvas-holder');
const scene=new THREE.Scene();
const camera=new THREE.PerspectiveCamera(50,1,0.05,120);
const renderer=new THREE.WebGLRenderer({antialias:true,alpha:true});
renderer.setPixelRatio(Math.min(devicePixelRatio,2));
holder.appendChild(renderer.domElement);

scene.add(new THREE.AmbientLight(0xfff2e0,.55));
const key=new THREE.DirectionalLight(0xffe6c4,.85); key.position.set(4,7,-3); scene.add(key);
const fill=new THREE.DirectionalLight(0xbfd4e0,.3); fill.position.set(-5,4,4); scene.add(fill);
const scr=new THREE.PointLight(0x88aaff,.5,7); scr.position.set(X0,1.6,2.4); scene.add(scr);

function box(w,h,d,c,x,y,z,ry=0,op=1){
  const m=new THREE.Mesh(new THREE.BoxGeometry(w,h,d),
    new THREE.MeshStandardMaterial({color:c,roughness:.85,metalness:.05,transparent:op<1,opacity:op}));
  m.position.set(x,y,z); m.rotation.y=ry; scene.add(m); return m;
}
function cyl(r,h,c,x,y,z){
  const m=new THREE.Mesh(new THREE.CylinderGeometry(r,r,h,28),
    new THREE.MeshStandardMaterial({color:c,roughness:.7}));
  m.position.set(x,y,z); scene.add(m); return m;
}

/* ---- โครงห้อง: กล่องกลับด้าน มองทะลุจากนอกได้ ---- */
const shell=new THREE.Mesh(new THREE.BoxGeometry(7.5,2.8,5.8),
  new THREE.MeshStandardMaterial({color:0x9a9083,roughness:.95,side:THREE.BackSide}));
shell.position.set(0,1.4,0); scene.add(shell);
const floor=new THREE.Mesh(new THREE.PlaneGeometry(7.5,5.8),
